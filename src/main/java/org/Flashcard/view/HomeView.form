<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="org.Flashcard.view.HomeView">
  <grid id="27dc6" binding="rootPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="5d95d" class="javax.swing.JList" binding="deckList">
        <constraints border-constraint="Center"/>
        <properties/>
      </component>
      <grid id="c1f9f" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
        <constraints border-constraint="South"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="a50ad" class="javax.swing.JButton" binding="createDeckButton">
            <constraints/>
            <properties>
              <text value="Create Deck"/>
            </properties>
          </component>
        </children>
      </grid>
    </children>
  </grid>
</form>
